# Kakao OAuth
REACT_APP_KAKAO_CLIENT_ID=your_kakao_rest_api_key
REACT_APP_KAKAO_CLIENT_SECRET=your_kakao_client_secret
REACT_APP_KAKAO_REDIRECT_URI=http://localhost:3000/member/kakao

# Google OAuth
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id
REACT_APP_GOOGLE_CLIENT_SECRET=your_google_client_secret
REACT_APP_GOOGLE_REDIRECT_URI=http://localhost:3000/member/google

# Naver OAuth
REACT_APP_NAVER_CLIENT_ID=your_naver_client_id
REACT_APP_NAVER_CLIENT_SECRET=your_naver_client_secret
REACT_APP_NAVER_REDIRECT_URI=http://localhost:3000/member/naver
